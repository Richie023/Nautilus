# Server
PORT=3001
NODE_ENV=development

# Security - CHANGE THESE IN PRODUCTION
ENCRYPTION_KEY=nautilus-change-this-32-char-key!!
JWT_SECRET=nautilus-jwt-secret-change-in-prod

# Database
DB_PATH=./data/nautilus.db

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
